# Application Configuration
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Upload Configuration
MAX_FILE_SIZE=10485760
MAX_UPLOAD_DIMENSION=4096
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,image/webp

# Storage Configuration (Future)
STORAGE_PROVIDER=local
# S3_BUCKET=your-bucket-name
# S3_REGION=us-east-1
# S3_ACCESS_KEY_ID=your-access-key
# S3_SECRET_ACCESS_KEY=your-secret-key

# ML Models (Future)
ENABLE_ML_FEATURES=false
MODEL_PATH=./models

# Processing Configuration
ENABLE_JOB_QUEUE=false
REDIS_URL=redis://localhost:6379

# Stripe (Future)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://neondb_owner:password@host.aws.neon.tech/neondb?sslmode=require

# Cloudinary Configuration (for Background Removal)
# Sign up at https://cloudinary.com/ to get these credentials
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Security
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MS=900000

